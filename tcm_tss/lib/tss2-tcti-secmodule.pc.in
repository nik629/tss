prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: tss2-tcti-secmodule
Description: TCTI library for communicating with a TPM secmodule node.
URL: https://github.com/tpm2-software/tpm2-tss
Version: @VERSION@
Requires.private: tss2-mu
Cflags: -I${includedir} -I${includedir}/tss2
Libs: -ltss2-tcti-secmodule -L${libdir}